---
import { site, nav, services } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-getij text-duin-50">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-klei/30" aria-hidden="true"></div>

  <div class="mx-auto max-w-[88rem] px-5 sm:px-8">
    <!-- afsluitende uitnodiging -->
    <div class="grid gap-10 border-b border-duin-50/12 py-16 md:grid-cols-[1.3fr_1fr] md:items-end md:py-24">
      <div>
        <p class="text-sm uppercase tracking-[0.24em] text-duin-50/50">Rustig beginnen</p>
        <h2 class="mt-5 max-w-[14ch] font-display text-[clamp(2.4rem,6vw,4.5rem)] leading-[0.98]">
          Begin met <span class="text-klei">luisteren</span>.
        </h2>
      </div>
      <div class="flex flex-col gap-3 md:items-end">
        <a href={site.whatsapp} data-magnetic class="press inline-flex w-fit items-center gap-2.5 rounded-full bg-klei px-7 py-4 font-semibold text-duin-50 transition-colors hover:bg-klei-400">
          Stuur een WhatsApp
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href={site.phoneHref} class="text-duin-50/70 transition-colors hover:text-duin-50">of bel {site.phoneDisplay}</a>
      </div>
    </div>

    <!-- kolommen -->
    <div class="grid gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex">
          <span class="font-display text-xl font-semibold leading-none tracking-[-0.03em]">Hondengedrag<span class="text-klei">&nbsp;Zeeland</span></span>
        </a>
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-duin-50/60">
          Hondengedragsbegeleiding in heel Zeeland. Achter elk gedrag zit een reden.
        </p>
      </div>

      <nav aria-label="Diensten">
        <p class="text-xs uppercase tracking-[0.2em] text-duin-50/40">Diensten</p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm text-duin-50/75">
          {services.map((s) => (
            <li><a class="link-underline" href={`/diensten#${s.slug}`}>{s.title}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Navigatie">
        <p class="text-xs uppercase tracking-[0.2em] text-duin-50/40">Meer</p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm text-duin-50/75">
          {nav.map((item) => (
            <li><a class="link-underline" href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-duin-50/40">Contact</p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm text-duin-50/75">
          <li><a class="link-underline" href={site.phoneHref}>{site.phoneDisplay}</a></li>
          <li><a class="link-underline break-all" href={`mailto:${site.email}`}>{site.email}</a></li>
          <li class="pt-2 text-duin-50/50">Werkgebied: heel Zeeland</li>
        </ul>
        <div class="mt-5 flex gap-3">
          <a href={site.instagram} aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-full border border-duin-50/15 transition-colors hover:border-klei hover:text-klei">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.facebook} aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-full border border-duin-50/15 transition-colors hover:border-klei hover:text-klei">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9V7c0-1 .3-1.5 1.6-1.5H17V2.4C16.6 2.3 15.5 2.2 14.4 2.2c-2.6 0-4.1 1.5-4.1 4.3V9H8v3h2.3v9H14v-9h2.4l.4-3H14z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- onderbalk -->
    <div class="flex flex-col gap-3 border-t border-duin-50/12 py-7 text-xs text-duin-50/45 md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} Hondengedrag Zeeland · KvK {site.kvk} · BTW {site.btw}</p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a class="link-underline" href="/voorwaarden">Algemene voorwaarden</a>
        <span class="text-duin-50/55">Conceptdemo door <a class="link-underline text-duin-50/75" href="https://agensea.nl">Agensea</a></span>
      </div>
    </div>
  </div>
</footer>
