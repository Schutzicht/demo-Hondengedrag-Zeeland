---
import Base from "../layouts/Base.astro";
import { prices } from "../data/site";

const notes = [
  "Voor- en nazorg via app of telefoon zit bij een consult inbegrepen.",
  "Geen abonnement en geen verplichtingen. We kijken steeds wat jouw hond nodig heeft.",
  "Ik werk in heel Zeeland. Reiskosten bespreken we vooraf, zodat je nooit voor verrassingen staat.",
];
---

<Base title="Tarieven" headerTone="light" description="Heldere tarieven voor consult aan huis, cursussen en groepswandelingen. Geen verrassingen, voor- en nazorg inbegrepen.">
  <section class="bg-duin pt-36 pb-[clamp(3rem,7vw,5rem)] sm:pt-40">
    <div class="mx-auto max-w-[80rem] px-5 sm:px-8">
      <p data-reveal class="text-[0.78rem] uppercase tracking-[0.26em] text-salie">Tarieven</p>
      <h1 data-reveal style="--d:.06s" class="mt-6 max-w-[16ch] font-display text-[clamp(2.6rem,7vw,5.4rem)] leading-[0.96] text-den">
        Helder, eerlijk en zonder kleine lettertjes
      </h1>
      <p data-reveal style="--d:.12s" class="mt-7 max-w-[48ch] text-lg leading-relaxed text-den/70">
        Je weet vooraf waar je aan toe bent. Wat je betaalt is wat je krijgt: aandacht, inzicht en een plan dat werkt.
      </p>
    </div>
  </section>

  <section class="bg-duin pb-[clamp(4rem,9vw,7rem)]">
    <div class="mx-auto max-w-[72rem] px-5 sm:px-8">
      <div class="overflow-hidden rounded-[4px] border border-den/10">
        {prices.map((p, i) => (
          <div data-reveal style={`--d:${i * 0.04}s`} class="group grid grid-cols-[1fr_auto] items-center gap-4 border-b border-den/10 bg-duin px-6 py-6 transition-colors last:border-b-0 hover:bg-duin-200/40 sm:px-9 sm:py-7">
            <div class="min-w-0">
              <h2 class="font-display text-xl text-den sm:text-2xl">{p.name}</h2>
              <p class="mt-1 text-sm text-den/55">{p.note}</p>
            </div>
            <p class="font-display text-2xl text-den sm:text-3xl">{p.price}</p>
          </div>
        ))}
      </div>

      <ul class="mt-10 flex flex-col gap-3">
        {notes.map((n, i) => (
          <li data-reveal style={`--d:${i * 0.05}s`} class="flex items-start gap-3 text-den/70">
            <svg class="mt-1 h-4 w-4 shrink-0 text-klei" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            {n}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="bg-getij py-[clamp(4rem,10vw,7rem)] text-duin-50">
    <div class="mx-auto max-w-[80rem] px-5 sm:px-8">
      <div class="grid items-center gap-8 md:grid-cols-[1.4fr_1fr]">
        <h2 data-reveal class="font-display text-[clamp(1.9rem,4.6vw,3.4rem)] leading-[1.03]">
          Twijfel je waar te beginnen? Dat hoeft niet alleen.
        </h2>
        <div data-reveal style="--d:.08s" class="md:justify-self-end">
          <a href="/contact" class="btn bg-klei px-7 py-4 text-duin-50 hover:bg-klei-400">Plan een kennismaking</a>
        </div>
      </div>
    </div>
  </section>
</Base>
