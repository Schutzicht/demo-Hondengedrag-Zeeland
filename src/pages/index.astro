---
import Base from "../layouts/Base.astro";
import { site, services, steps, signals } from "../data/site";
---

<Base headerTone="dark">
  <!-- ============ HERO ============ -->
  <section class="hero relative flex min-h-[100svh] items-center overflow-hidden bg-getij">
    <div class="absolute inset-0">
      <img
        src="/images/art/hero-dijk.png"
        alt="Baas wandelt met hond aan een losse lijn over de Zeeuwse dijk bij dageraad"
        class="kenburns h-full w-full object-cover object-[center_56%]"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background:linear-gradient(82deg, rgba(15,39,34,.85) 0%, rgba(15,39,34,.42) 42%, rgba(15,39,34,0) 74%)"></div>
      <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(15,39,34,.30) 0%, transparent 28%, transparent 54%, rgba(15,39,34,.82) 100%)"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-[80rem] px-6 py-24 sm:px-8">
      <p data-reveal class="mb-6 flex items-center gap-3 text-[0.74rem] font-medium uppercase tracking-[0.24em] text-duin-50/80">
        <span class="inline-block h-px w-9 bg-klei"></span>
        {site.role} in heel Zeeland
      </p>
      <h1 data-reveal style="--d:.08s" class="display max-w-[15ch] font-display text-[clamp(2.4rem,7.5vw,6.4rem)] font-semibold leading-[1.0] text-duin-50">
        Achter elk gedrag zit een reden.
      </h1>
      <p data-reveal style="--d:.16s" class="mt-7 max-w-[46ch] text-lg leading-relaxed text-duin-50/85">
        {site.intro}
      </p>
      <div data-reveal style="--d:.24s" class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href="/contact" class="btn bg-klei px-7 py-4 text-duin-50 hover:bg-klei-400">Plan een kennismaking</a>
        <a href="#aanpak" class="btn border border-duin-50/30 px-7 py-4 text-duin-50 hover:bg-duin-50/10">Bekijk de aanpak</a>
      </div>
    </div>

    <div class="absolute inset-x-0 bottom-7 z-10 mx-auto flex w-full max-w-[80rem] items-center gap-3 px-6 text-duin-50/55 sm:px-8">
      <span class="scroll-cue inline-block h-9 w-px bg-duin-50/40"></span>
      <span class="text-xs uppercase tracking-[0.18em]">Scroll</span>
    </div>
  </section>

  <!-- ============ INTRO ============ -->
  <section class="bg-duin py-[clamp(5.5rem,12vw,9rem)]">
    <div class="mx-auto max-w-[80rem] px-6 sm:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-24">
        <div>
          <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-salie">Gedrag is communicatie</p>
          <h2 data-reveal style="--d:.06s" class="mt-6 font-display text-[clamp(1.9rem,4vw,3.1rem)] font-semibold leading-[1.08] text-den">
            Een hond die blaft, trekt of uitvalt is niet stout. Hij vertelt iets.
          </h2>
        </div>
        <div class="flex flex-col gap-6 self-center text-lg leading-relaxed text-den/70">
          <p data-reveal style="--d:.1s">
            De meeste trainingen werken aan het gedrag zelf: afleren, corrigeren, belonen. Ik kijk een stap eerder, naar de reden eronder. Want pas als je begrijpt waarom je hond reageert, verandert er iets dat blijft.
          </p>
          <p data-reveal style="--d:.16s">
            Geen strak schema en geen trucjes. Wel rust, ruimte en een manier van kijken die je daarna nooit meer verleert.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LEER JE HOND LEZEN ============ -->
  <section class="bg-duin-100 py-[clamp(5.5rem,12vw,9rem)]">
    <div class="mx-auto max-w-[80rem] px-6 sm:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="lg:sticky lg:top-24 lg:self-start">
          <div class="reveal-media relative aspect-[4/5] overflow-hidden rounded-[3px]">
            <img src="/images/art/stille-taal.png" alt="Rustige hond met ontspannen lichaamstaal" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="lg:py-6">
          <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-salie">De stille taal</p>
          <h2 data-reveal style="--d:.06s" class="mt-5 font-display text-[clamp(1.9rem,4vw,3rem)] font-semibold leading-[1.06] text-den">
            Leer je hond lezen
          </h2>
          <p data-reveal style="--d:.1s" class="mt-5 max-w-[48ch] text-lg leading-relaxed text-den/70">
            Een hond praat de hele dag tegen je, alleen niet met woorden. Vijf signalen vertellen samen het hele verhaal. Bij een ontspannen hond zie je dit:
          </p>
          <ul class="mt-9 border-t border-den/10">
            {signals.map((s, i) => (
              <li data-reveal style={`--d:${0.12 + i * 0.04}s`} class="flex gap-5 border-b border-den/10 py-5">
                <span class="w-6 shrink-0 pt-1 font-display text-sm text-klei">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <h3 class="font-display text-lg text-den">{s.label}</h3>
                  <p class="mt-1 text-[0.96rem] leading-relaxed text-den/65">{s.calm}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ DE AANPAK ============ -->
  <section id="aanpak" class="bg-getij py-[clamp(5.5rem,12vw,9rem)] text-duin-50">
    <div class="mx-auto max-w-[80rem] px-6 sm:px-8">
      <div class="max-w-[40ch]">
        <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-klei-400">De aanpak</p>
        <h2 data-reveal style="--d:.06s" class="mt-5 font-display text-[clamp(1.9rem,4.4vw,3.4rem)] font-semibold leading-[1.04]">
          Van onrust naar rust, in vier stappen
        </h2>
        <p data-reveal style="--d:.1s" class="mt-5 text-duin-50/70">
          Geen dwang en geen trucjes, maar inzicht. Stap voor stap gaat de spanning eraf, bij jou en bij je hond.
        </p>
      </div>

      <ol class="mt-14 border-t border-duin-50/12">
        {steps.map((step, i) => (
          <li data-reveal style={`--d:${i * 0.04}s`} class="grid gap-3 border-b border-duin-50/12 py-9 sm:grid-cols-[8rem_1fr] sm:gap-12 sm:py-11">
            <span class="font-display text-[clamp(2rem,4vw,2.8rem)] font-semibold leading-none text-klei-400/90">{step.n}</span>
            <div>
              <h3 class="font-display text-[clamp(1.4rem,2.6vw,1.9rem)] font-semibold leading-tight">{step.title}</h3>
              <p class="mt-1.5 text-lg text-klei-400/90">{step.line}</p>
              <p class="mt-4 max-w-[58ch] leading-relaxed text-duin-50/72">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ DIENSTEN ============ -->
  <section class="bg-duin py-[clamp(5.5rem,12vw,9rem)]">
    <div class="mx-auto max-w-[80rem] px-6 sm:px-8">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-salie">Diensten</p>
          <h2 data-reveal style="--d:.06s" class="mt-5 font-display text-[clamp(1.9rem,4.4vw,3.2rem)] font-semibold leading-[1.04] text-den">
            Vier wegen naar rust
          </h2>
        </div>
        <a data-reveal style="--d:.1s" href="/diensten" class="link-underline hidden text-sm font-semibold text-den sm:block">
          Alle diensten en tarieven
        </a>
      </div>

      <div class="mt-12 grid gap-x-8 gap-y-12 sm:grid-cols-2">
        {services.map((s, i) => (
          <a href={`/diensten#${s.slug}`} data-reveal style={`--d:${(i % 2) * 0.06}s`} class="group block">
            <div class="relative aspect-[16/11] overflow-hidden rounded-[3px] bg-duin-200">
              <img
                src={s.image}
                alt={s.imageAlt}
                class="h-full w-full object-cover transition-transform duration-[850ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.045]"
                loading="lazy"
              />
            </div>
            <div class="mt-5 flex items-start justify-between gap-5 border-t border-den/10 pt-4">
              <div>
                <h3 class="font-display text-[1.45rem] font-semibold leading-snug text-den">{s.title}</h3>
                <p class="mt-1 text-den/55">{s.kicker}</p>
              </div>
              <div class="flex shrink-0 items-center gap-4 pt-1">
                <span class="hidden whitespace-nowrap text-sm text-den/60 sm:block">{s.price}</span>
                <span class="flex h-10 w-10 items-center justify-center rounded-full border border-den/20 text-den transition-colors duration-400 group-hover:border-klei group-hover:bg-klei group-hover:text-duin-50">
                  <svg class="h-4 w-4 transition-transform duration-400 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <a href="/diensten" class="link-underline mt-10 inline-block text-sm font-semibold text-den sm:hidden">Alle diensten en tarieven</a>
    </div>
  </section>

  <!-- ============ PIETERNEL ============ -->
  <section class="bg-duin-100 py-[clamp(5.5rem,12vw,9rem)]">
    <div class="mx-auto grid max-w-[80rem] gap-12 px-6 sm:px-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:gap-20">
      <div class="reveal-media relative aspect-[4/5] overflow-hidden rounded-[3px]">
        <img src="/images/real/pieternel-van-haaften.jpg" alt="Pieternel van Haaften, hondengedragsconsulent" class="h-full w-full object-cover object-[center_20%]" loading="lazy" />
      </div>
      <div>
        <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-salie">Wie je begeleidt</p>
        <h2 data-reveal style="--d:.06s" class="mt-5 font-display text-[clamp(1.9rem,4vw,3.1rem)] font-semibold leading-[1.04] text-den">
          Pieternel van Haaften
        </h2>
        <p data-reveal style="--d:.1s" class="mt-6 max-w-[50ch] text-lg leading-relaxed text-den/80">
          Dertig jaar werkte ik in de zorg voor mensen met een verstandelijke beperking. Daar leerde ik wat echt contact vraagt: geduld, rust en heel goed kijken.
        </p>
        <p data-reveal style="--d:.16s" class="mt-4 max-w-[50ch] leading-relaxed text-den/65">
          Die houding nam ik mee naar honden. Niet sturen op gedrag, maar op begrip. Met meerdere diploma's in hondenpsychologie en een rustige, respectvolle benadering.
        </p>
        <a data-reveal style="--d:.2s" href="/over-pieternel" class="btn mt-8 border border-den/20 px-6 py-3.5 text-den hover:bg-den hover:text-duin-50">
          Lees mijn verhaal
        </a>
      </div>
    </div>
  </section>

  <!-- ============ ZEELAND ============ -->
  <section class="relative flex min-h-[70svh] items-end overflow-hidden bg-getij text-duin-50">
    <div class="absolute inset-0" style="background-image:url('/images/art/kust-ochtend.png');background-size:cover;background-position:center" aria-hidden="true"></div>
    <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(15,39,34,.5),rgba(15,39,34,.2) 40%,rgba(15,39,34,.9))" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto w-full max-w-[80rem] px-6 py-20 sm:px-8">
      <p data-reveal class="text-[0.74rem] font-medium uppercase tracking-[0.22em] text-klei-400">Werkgebied</p>
      <h2 data-reveal style="--d:.06s" class="mt-5 max-w-[20ch] font-display text-[clamp(2rem,5vw,4rem)] font-semibold leading-[1.0]">
        Door heel Zeeland, dichtbij waar je woont
      </h2>
      <ul data-reveal style="--d:.12s" class="mt-9 flex flex-wrap gap-x-7 gap-y-3 text-lg text-duin-50/90">
        {site.towns.map((t) => (
          <li class="flex items-center gap-2.5"><span class="inline-block h-1.5 w-1.5 rounded-full bg-klei"></span>{t}</li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .kenburns { animation: kb 28s var(--ease-quint) infinite alternate; will-change: transform; }
    @keyframes kb { from { transform: scale(1.04); } to { transform: scale(1.12); } }
    .scroll-cue { transform-origin: top; animation: cue 2.4s var(--ease-quint) infinite; }
    @keyframes cue { 0%,100% { transform: scaleY(0.4); opacity: 0.4; } 50% { transform: scaleY(1); opacity: 1; } }
    @media (prefers-reduced-motion: reduce) { .kenburns, .scroll-cue { animation: none; } }
  </style>
</Base>
